# Normalizzazione line endings cross-platform
# Git converte automaticamente CRLF↔LF al checkout/commit dove serve.
* text=auto eol=lf

# Sorgenti testuali (forzati a LF)
*.py         text eol=lf
*.sh         text eol=lf
*.json       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.md         text eol=lf
*.txt        text eol=lf
*.toml       text eol=lf
*.cfg        text eol=lf
*.ini        text eol=lf
Dockerfile   text eol=lf
Makefile     text eol=lf
.env.example text eol=lf
.gitignore   text eol=lf
.gitattributes text eol=lf

# File binari (no diff, no line ending conversion)
*.pdf    binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pkl    binary
*.bin    binary
*.gguf   binary
*.safetensors binary

# Linguaggi per statistiche GitHub (Linguist)
*.py linguist-language=Python
