# ============================================================
# ai_ocr — variabili d'ambiente
# Copia questo file in `.env` e compila con i tuoi valori reali.
# Il file `.env` NON viene committato (vedi .gitignore).
# ============================================================

# Codice fiscale del cedente (11 cifre per P.IVA, 16 caratteri per CF)
# Usato dal servizio fatture-converter per popolare la colonna "CF cedente"
# del CSV di import in Ago Zucchetti.
CF_CEDENTE=

# Nome del cedente (es. "FARMACIA ESEMPIO SRL"), usato per riconoscere ed
# escludere la riga del cedente quando si estrae il nominativo del cessionario.
# Lascia vuoto se non serve.
NOME_CEDENTE=
